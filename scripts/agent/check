#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/scripts/agent/lib.sh"
"$ROOT/scripts/agent/fmt-check"
"$ROOT/scripts/agent/vet"
"$ROOT/scripts/agent/test"
"$ROOT/scripts/agent/build"
"$ROOT/scripts/agent/mod-tidy-check"
"$ROOT/scripts/agent/mod-verify"
"$ROOT/scripts/agent/ts-fmt-check"
"$ROOT/scripts/agent/ts-lint"
"$ROOT/scripts/agent/conformance"
"$ROOT/scripts/agent/coverage"
"$ROOT/scripts/agent/release-check"
todo_port="${TODO_API_PORT:-$((20000 + RANDOM % 10000))}"
widget_port="${WIDGET_API_PORT:-$((30000 + RANDOM % 10000))}"
capabilities_api_port="${CAPABILITIES_API_PORT:-$((50000 + RANDOM % 10000))}"
capabilities_webhook_port="${CAPABILITIES_WEBHOOK_PORT:-$((51000 + RANDOM % 10000))}"
TODO_API_PORT="$todo_port" "$ROOT/scripts/agent/example-todo"
WIDGET_API_PORT="$widget_port" "$ROOT/scripts/agent/example-advanced"
CAPABILITIES_API_PORT="$capabilities_api_port" CAPABILITIES_WEBHOOK_PORT="$capabilities_webhook_port" "$ROOT/scripts/agent/example-capabilities"
agent_note "ok check"
