#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/scripts/agent/lib.sh"
"$ROOT/scripts/agent/build"
fixture="$TYPESCRIPT_ROOT/fixtures/generated/client"
rm -rf "$fixture"
agent_run "generate TypeScript fixture" "$ROOT/.tmp/bin/openapi-sdkgen" generate \
  --input "$TYPESCRIPT_ROOT/fixtures/contract.openapi.json" \
  --target typescript \
  --output "$fixture"
