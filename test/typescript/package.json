{
  "name": "openapi-sdkgen-typescript-conformance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "conformance": "corepack pnpm run typecheck && corepack pnpm run test"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.11.0"
  },
  "packageManager": "pnpm@11.11.0"
}
